{
  "name": "eventra",
  "version": "1.0.0",
  "private": true,
  "description": "Eventra - Campus Connect Hub",
  "scripts": {
    "dev:backend": "cd backend && .\\venv\\Scripts\\python.exe -m uvicorn main:app --reload",
    "dev:frontend": "cd campus-connect-hub && bun run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "npm run dev",
    "install:all": "npm install && cd campus-connect-hub && bun install && cd ../backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
